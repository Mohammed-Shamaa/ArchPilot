{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/archpilot-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=archpilot;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Key": "ArchPilot_SuperSecretKey_2024_MustBeAtLeast32CharactersLong!",
    "Issuer": "ArchPilot",
    "Audience": "ArchPilot",
    "ExpiryMinutes": "60",
    "RefreshExpiryDays": "7"
  },
  "AI": {
    "ApiUrl": "https://api.x.ai/v1",
    "ApiKey": "",
    "Model": "grok-3"
  },
  "Cors": {
    "Origins": ["http://localhost:3000", "https://archpilot.vercel.app", "https://archpilot-ecru.vercel.app", "https://archpilot-git-master-mohammed-shamaas-projects.vercel.app", "https://archpilot-373b0nh9m-mohammed-shamaas-projects.vercel.app"]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Forwarded-For",
    "ClientIdHeader": "X-ClientId",
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "15m",
        "Limit": 1000
      },
      {
        "Endpoint": "post:/api/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "post:/api/auth/register",
        "Period": "5m",
        "Limit": 5
      },
      {
        "Endpoint": "post:/api/ai/chat",
        "Period": "1m",
        "Limit": 30
      }
    ]
  }
}
